{
  "name": "dudu-syntax",
  "displayName": "Dudu",
  "description": "Syntax highlighting, formatting, diagnostics, and commands for Dudu .dd source files.",
  "version": "0.1.0",
  "publisher": "dudu",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onLanguage:dudu",
    "onCommand:dudu.fmtFile",
    "onCommand:dudu.checkFile",
    "onCommand:dudu.buildProject",
    "onCommand:dudu.runFile",
    "onCommand:dudu.testProject",
    "onCommand:dudu.restartLsp"
  ],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "dudu",
        "aliases": [
          "Dudu",
          "dudu"
        ],
        "extensions": [
          ".dd"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dudu",
        "scopeName": "source.dudu",
        "path": "./syntaxes/dudu.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[dudu]": {
        "editor.inlayHints.enabled": "offUnlessPressed"
      }
    },
    "commands": [
      {
        "command": "dudu.fmtFile",
        "title": "Dudu: Format Current File"
      },
      {
        "command": "dudu.checkFile",
        "title": "Dudu: Check Current File"
      },
      {
        "command": "dudu.buildProject",
        "title": "Dudu: Build Project"
      },
      {
        "command": "dudu.runFile",
        "title": "Dudu: Run Current File"
      },
      {
        "command": "dudu.testProject",
        "title": "Dudu: Test Project"
      },
      {
        "command": "dudu.restartLsp",
        "title": "Dudu: Restart Language Server"
      }
    ],
    "configuration": {
      "title": "Dudu",
      "properties": {
        "dudu.path": {
          "type": "string",
          "default": "dudu",
          "description": "Path to the Dudu project driver executable used by editor commands."
        },
        "dudu.lspPath": {
          "type": "string",
          "default": "dudu-lsp",
          "description": "Path to the Dudu language server executable."
        },
        "dudu.inlayHints.inferredTypes": {
          "type": "boolean",
          "default": true,
          "description": "Show inlay hints for inferred local binding types."
        },
        "dudu.inlayHints.loopBindingTypes": {
          "type": "boolean",
          "default": true,
          "description": "Show inlay hints for inferred for-loop binding types."
        },
        "dudu.inlayHints.implicitSelf": {
          "type": "boolean",
          "default": true,
          "description": "Show inlay hints for implicit method receiver type, such as self: &Self."
        },
        "dudu.inlayHints.parameterNames": {
          "type": "boolean",
          "default": true,
          "description": "Show inlay hints for positional call parameter names."
        },
        "dudu.inlayHints.argumentTypes": {
          "type": "boolean",
          "default": false,
          "description": "Show inlay hints for argument expression types. This is useful for debugging inference but can be noisy."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.1"
  }
}
