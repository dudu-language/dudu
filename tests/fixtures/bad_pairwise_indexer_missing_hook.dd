class PairwiseIndexer:
    cols: i32


class Tensor:
    rows: i32
    cols: i32
    pairwise: PairwiseIndexer


def main() -> i32:
    tensor = Tensor(2, 2, PairwiseIndexer(2))
    rows: array[i32] = [0, 1]
    cols: array[i32] = [1, 0]
    value = tensor.pairwise[rows, cols]
    return i32(value)
