class ImageBox[Rows, Cols, Channels]:
    pixels: array[i32][Rows, Cols, Channels]

    def pixel_tail_sum(self, row: i32, col: i32) -> i32:
        channels: span[i32] = self.pixels[row, col, 1:]
        total: i32 = 0
        for value: i32 in channels:
            total += value
        return total


def main() -> i32:
    image: array[i32] = [
        [[1, 2, 3, 4], [10, 20, 30, 40]],
        [[5, 6, 7, 8], [50, 60, 70, 80]],
    ]
    box: ImageBox[2, 2, 4] = ImageBox[2, 2, 4](image)
    return box.pixel_tail_sum(1, 1)
