class CartesianIndexer:
    data: list[i32]
    cols: i32

    @operator("[]")
    def at(self, rows: array[i32][2], cols: array[i32][2]) -> i32:
        return (
            self.data[(rows[0] * self.cols) + cols[0]]
            + self.data[(rows[0] * self.cols) + cols[1]]
            + self.data[(rows[1] * self.cols) + cols[0]]
            + self.data[(rows[1] * self.cols) + cols[1]]
        )

    @operator("[]=")
    def set_at(self, rows: array[i32][2], cols: array[i32][2], value: i32):
        self.data[(rows[0] * self.cols) + cols[0]] = value
        self.data[(rows[0] * self.cols) + cols[1]] = value
        self.data[(rows[1] * self.cols) + cols[0]] = value
        self.data[(rows[1] * self.cols) + cols[1]] = value


class Tensor:
    rows: i32
    cols: i32
    data: list[i32]
    cartesian: CartesianIndexer

    @operator("[]")
    def at(self, row: i32, col: i32) -> i32:
        return self.data[(row * self.cols) + col]

    @operator("[]=")
    def set_at(self, row: i32, col: i32, value: i32):
        self.data[(row * self.cols) + col] = value


def main() -> i32:
    data: list[i32] = [1, 2, 3, 4]
    tensor = Tensor(2, 2, data, CartesianIndexer(data, 2))
    rows: array[i32] = [0, 1]
    cols: array[i32] = [0, 1]
    before = tensor.cartesian[rows, cols]
    tensor.cartesian[rows, cols] += 1
    after = tensor.cartesian[rows, cols]
    return before + after - 12
