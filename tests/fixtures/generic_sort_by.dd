from cpp import algorithm


def less_i32(left: i32, right: i32) -> bool:
    return left < right


def greater_i32(left: i32, right: i32) -> bool:
    return left > right


def sort_by[T](values: &list[T], cmp: fn(T, T) -> bool):
    std.sort(values.begin(), values.end(), cmp)


def main() -> i32:
    values: list[i32] = [9, 4, 7, 1, 3]
    sort_by(values, greater_i32)
    if values[0] != 9:
        return 1
    sort_by(values, less_i32)
    if values[0] == 1 and values[4] == 9:
        return 42
    return 2
