class Mask:
    data: list[bool]


class Tensor[T]:
    rows: i32
    cols: i32
    data: list[T]

    @operator("[]")
    def masked_rows(self, mask: Mask, cols: slice) -> Tensor[T][dyn, 2]:
        return Tensor[T](self.rows, self.cols, self.data)

    @operator("[]=")
    def set_masked_rows(self, mask: Mask, cols: slice, value: T):
        self.data[0] = value


def main() -> i32:
    mask = Mask([])
    values = Tensor[i32](1, 2, [10, 11])
    values[mask, :] += 1
    return 0
