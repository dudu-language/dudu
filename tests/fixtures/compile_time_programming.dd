@align(16)
class PacketHeader:
    kind: u16
    flags: u16
    payload_size: u32


@constexpr
def align_up(value: usize, alignment: usize) -> usize:
    return (value + alignment - 1) & ~(alignment - 1)


PACKET_ALIGNMENT: usize = alignof[PacketHeader]()
PACKET_BYTES: usize = align_up(sizeof[PacketHeader](), PACKET_ALIGNMENT)
QUEUE_CAPACITY: usize = 64
LUT_BITS: usize = 8
LUT_SIZE: usize = 1 << LUT_BITS

static_assert(PACKET_ALIGNMENT == 16)
static_assert(PACKET_BYTES == 16)
static_assert(QUEUE_CAPACITY % 2 == 0)
static_assert(LUT_SIZE == 256)


def selected_backend() -> i32:
    if build.RENDER_BACKEND == "vulkan":
        return 2
    elif build.RENDER_BACKEND == "raylib":
        return 1
    return 0


def main() -> i32:
    queue: array[u32][QUEUE_CAPACITY]
    lut: array[u8][LUT_SIZE]
    return i32(len(queue)) + i32(len(lut)) + selected_backend()
