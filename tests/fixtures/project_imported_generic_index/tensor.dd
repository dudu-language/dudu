class Tensor[T]:
    values: list[T]

    @operator("[]")
    def at(self, index: i32) -> T:
        return self.values[index]

    @operator("[]=")
    def set_at(self, index: i32, value: T):
        self.values[index] = value


def make_tensor[T](a: T, b: T) -> Tensor[T]:
    values: list[T] = []
    values.append(a)
    values.append(b)
    return Tensor[T](values)
