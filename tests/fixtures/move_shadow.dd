# User declarations remain normal call targets even when they share a builtin name.
def move(value: i32) -> i32:
    return value + 1


def add_one(value: i32) -> i32:
    return value + 1


def call_declared_move() -> i32:
    return move(41)


def main() -> i32:
    move: fn(i32) -> i32 = add_one
    if move(40) != 41:
        return 1
    return call_declared_move()
