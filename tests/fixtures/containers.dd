def main() -> i32:
    values = [12, 30]
    scores = {"bob": 20, "ada": 22}
    seen = {"bob", "ada"}
    values.push_back(12)
    values.push_back(30)
    score_total = 0
    for name in scores:
        score_total += scores[name]
    if seen.contains("bob"):
        return values[0] + values[1] + score_total - 42
    return 1
