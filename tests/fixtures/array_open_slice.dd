def sum_view(values: span[i32]) -> i32:
    total: i32 = 0
    for value: i32 in values:
        total += value
    return total


def main() -> i32:
    values: array[i32] = [4, 10, 20, 12, 6]
    head: span[i32] = values[:3]
    tail: span[i32] = values[2:]
    all_values: span[i32] = values[:]
    if sum_view(head) == 34 and sum_view(tail) == 38 and sum_view(all_values) == 52:
        return 42
    return 1
