class CartesianIndexer:
    cols: i32


class Tensor:
    rows: i32
    cols: i32
    cartesian: CartesianIndexer


def main() -> i32:
    tensor = Tensor(2, 2, CartesianIndexer(2))
    rows: array[i32] = [0, 1]
    cols: array[i32] = [1, 0]
    value = tensor.cartesian[rows, cols]
    return i32(value)
