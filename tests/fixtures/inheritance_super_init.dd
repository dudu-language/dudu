class Entity:
    id: i32

    def init(self, id: i32):
        self.id = id

    def score(self) -> i32:
        return self.id


class Player(Entity):
    bonus: i32

    def init(self, id: i32, bonus: i32):
        super.init(id)
        self.bonus = bonus

    def score(self) -> i32:
        return super.score() + self.bonus


def main() -> i32:
    player: Player = Player(30, 12)
    return player.score()
