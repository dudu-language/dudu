def sum_view(values: array_view[i32]) -> i32:
    total: i32 = 0
    for value: i32 in values:
        total += value
    return total


def sum_column[Rows, Cols](matrix: &array[i32][Rows, Cols], column_index: i32) -> i32:
    column: array_view[i32] = matrix[:, column_index]
    return sum_view(column)


def main() -> i32:
    matrix: array[i32] = [
        [1, 2, 3],
        [10, 20, 30],
        [4, 5, 6],
    ]
    return sum_column[3, 3](matrix, 1)
