from c.path import stdlib.h as c


def compare_i32(left: *const[void], right: *const[void]) -> i32:
    a: *const[i32] = *const[i32](left)
    b: *const[i32] = *const[i32](right)
    if *a < *b:
        return -1
    if *a > *b:
        return 1
    return 0


def main() -> i32:
    values: array[i32][4]
    values[0] = 9
    values[1] = 2
    values[2] = 7
    values[3] = 4
    c.qsort(&values[0], 4, sizeof[i32](), compare_i32)
    return values[0] + values[1] + values[2] + values[3] + values[0]
