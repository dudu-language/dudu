from c import time.h


def add_seconds(ts: *timespec) -> i32:
    return i32(ts.tv_sec + ts.tv_nsec)


def by_value(ts: timespec) -> i32:
    return i32(ts.tv_sec - ts.tv_nsec)


def main() -> i32:
    ts: timespec
    ts.tv_sec = 40
    ts.tv_nsec = 2
    return add_seconds(&ts) + by_value(ts) - 38
