import c "../tests/fixtures/c_audio_callback.h" as audio


def fill_samples(output: *f32, frames: i32, user_data: *void):
    state: *struct dudu_audio_state = *struct dudu_audio_state(user_data)
    for i: i32 in range(frames):
        output[i] = state.phase
        state.phase += state.step
    state.calls += 1


def main() -> i32:
    state: struct dudu_audio_state
    state.phase = 1.0
    state.step = 2.0
    state.calls = 0
    samples: f32[4]

    audio.dudu_audio_run(fill_samples, &state, &samples[0], 4)

    total: i32 = i32(samples[0]) + i32(samples[1]) + i32(samples[2]) + i32(samples[3])
    return total + state.calls + i32(state.phase)
