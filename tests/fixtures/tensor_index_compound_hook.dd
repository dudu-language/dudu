class Tensor2:
    values: array[i32][4]

    @operator("[]")
    def at(self, index: i32) -> i32:
        return self.values[index]

    @operator("[]=")
    def set_at(self, index: i32, value: i32):
        self.values[index] = value


def main() -> i32:
    values: array[i32] = [10, 2, 12, 1]
    tensor = Tensor2(values)
    tensor[1] += 20
    tensor[2] -= 2
    return tensor[0] + tensor[1] + tensor[2]
