def sum_to(limit: i32) -> i32:
    total: i32 = 0
    for i: i32 in range(1, limit + 1):
        total += i
    return total


def countdown(value: i32) -> i32:
    current: i32 = value
    while current > 3:
        current -= 1
    return current


def main() -> i32:
    total = sum_to(10)
    if countdown(8) == 3:
        return total
    else:
        return 1
