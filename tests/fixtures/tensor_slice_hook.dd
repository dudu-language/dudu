class Tensor:
    marker: i32

    @operator("[]")
    def at(self, rows: slice, col: i32) -> i32:
        return self.marker + col

    @operator("[]=")
    def set_at(self, rows: slice, col: i32, value: i32):
        self.marker = value + col


def main() -> i32:
    tensor = Tensor(1)
    tensor[1:3, 2] = 38
    return tensor[0:3:2, 4] - 2
