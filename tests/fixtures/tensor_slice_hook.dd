class Tensor:
    marker: i32

    @operator("[]")
    def at(self, rows: slice, col: i32) -> i32:
        if rows.has_start and rows.has_end and rows.has_step:
            return self.marker + col + i32(rows.start) + i32(rows.end) + i32(rows.step)
        return 1

    @operator("[]=")
    def set_at(self, rows: slice, col: i32, value: i32):
        if rows.has_start and rows.has_end:
            self.marker = value + col + i32(rows.start) + i32(rows.end)


def main() -> i32:
    tensor = Tensor(1)
    tensor[1:3, 2] = 28
    return tensor[0:3:2, 4] - 1
