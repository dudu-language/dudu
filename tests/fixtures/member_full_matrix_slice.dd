class MatrixBox[Rows, Cols]:
    items: array[i32][Rows, Cols]

    def total(self) -> i32:
        all_values: span[i32] = self.items[:, :]
        total: i32 = 0
        for value: i32 in all_values:
            total += value
        return total


def main() -> i32:
    matrix: array[i32] = [
        [8, 12],
        [10, 12],
    ]
    box: MatrixBox[2, 2] = MatrixBox[2, 2](matrix)
    return box.total()
