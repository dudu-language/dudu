def sum_view(values: span[i32]) -> i32:
    total: i32 = 0
    for value: i32 in values:
        total += value
    return total


def main() -> i32:
    matrix: array[i32] = [
        [1, 2, 3],
        [10, 20, 12],
        [4, 5, 6],
    ]
    rows: span[i32] = matrix[1:3, :]
    return sum_view(rows)
