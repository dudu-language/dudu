import c "lua.h" as lua
import c "lauxlib.h" as laux
import c "lualib.h" as lualib


def main() -> i32:
    state = laux.luaL_newstate()
    if state == None:
        return 1

    lualib.luaL_openlibs(state)

    code: str = "return 40 + 2"
    if laux.luaL_loadstring(state, code.c_str()) != lua.LUA_OK:
        lua.lua_close(state)
        return 2
    if lua.lua_pcallk(state, 0, 1, 0, 0, None) != lua.LUA_OK:
        lua.lua_close(state)
        return 3

    value = lua.lua_tointegerx(state, -1, None)
    top = lua.lua_gettop(state)
    lua.lua_close(state)

    if top != 1:
        return 4
    return i32(value)
