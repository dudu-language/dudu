from c import lauxlib.h
from c import lua.h
from c import lualib.h


def main() -> i32:
    state = luaL_newstate()
    if state == None:
        return 1

    luaL_openlibs(state)

    code: str = "return 40 + 2"
    if luaL_loadstring(state, code.c_str()) != LUA_OK:
        lua_close(state)
        return 2
    if lua_pcallk(state, 0, 1, 0, 0, None) != LUA_OK:
        lua_close(state)
        return 3

    value = lua_tointegerx(state, -1, None)
    top = lua_gettop(state)
    lua_close(state)

    if top != 1:
        return 4
    return i32(value)
