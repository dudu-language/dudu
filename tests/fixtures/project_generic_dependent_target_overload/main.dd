from protocol import Codec
from protocol import DecodeTarget
from protocol import Reader
from protocol import decode_from
from protocol import decode_result
from protocol import decode_sequence
from protocol import decode_static


class Probe:
    def decode[Input](input: &const[Input]) -> i32:
        decoded = decode_result(input.element(0), DecodeTarget[i32]())
        if not decoded.ok:
            return 0
        return decoded.value


def main() -> i32:
    input = Reader()
    decoded = decode_from[i32, Reader](input)
    sequence = decode_sequence(input, DecodeTarget[list[i32]]())
    static_value = decode_static[Codec, Reader](input)
    nested = Probe.decode(input)
    return decoded + sequence[0] + static_value + nested - 126
