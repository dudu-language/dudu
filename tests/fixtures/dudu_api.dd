ANSWER: i32 = 33


enum Status:
    Ok = 0
    Failed = 1


class Point:
    x: i32
    y: i32

    def _secret(self) -> i32:
        return self.x - self.y

    def sum(self) -> i32:
        return self.x + self.y + self._secret()


def answer() -> i32:
    return ANSWER


def make_point(x: i32, y: i32) -> Point:
    return Point(x=x, y=y)


def point_sum(point: Point) -> i32:
    return point.x + point.y
