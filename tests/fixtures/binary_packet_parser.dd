@packed
class PacketHeader:
    magic: u16
    version: u8
    flags: u8
    payload_size: u32


HEADER_SIZE: usize = sizeof[PacketHeader]()
FLAGS_OFFSET: usize = offsetof[PacketHeader](flags)

static_assert(HEADER_SIZE == 8)
static_assert(FLAGS_OFFSET == 3)


def read_le16(bytes: &u8[8], offset: usize) -> u16:
    lo: u16 = u16(bytes[offset])
    hi: u16 = u16(bytes[offset + 1]) * 256
    return lo | hi


def read_le32(bytes: &u8[8], offset: usize) -> u32:
    b0: u32 = u32(bytes[offset])
    b1: u32 = u32(bytes[offset + 1]) * 256
    b2: u32 = u32(bytes[offset + 2]) * 65536
    b3: u32 = u32(bytes[offset + 3]) * 16777216
    return b0 | b1 | b2 | b3


def main() -> i32:
    bytes: u8[8]
    bytes[0] = 0x34
    bytes[1] = 0x12
    bytes[2] = 0x02
    bytes[3] = 0x80
    bytes[4] = 0x2A
    bytes[5] = 0x00
    bytes[6] = 0x00
    bytes[7] = 0x00

    if read_le16(bytes, 0) != 0x1234:
        return 1
    if bytes[FLAGS_OFFSET] != 0x80:
        return 2
    return i32(read_le32(bytes, 4))
