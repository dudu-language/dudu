enum Message:
    Quit

    Move:
        x: i32
        y: i32

    Write(str)


def handle(msg: Message) -> i32:
    match msg:
        case Message.Quit:
            return 1
        case Message.Move(x, y):
            return x + y
        case Message.Write(text):
            return i32(len(text))


def handle_named(msg: Message) -> i32:
    match msg:
        case Message.Quit:
            return 0
        case Message.Move(y=dy, x=dx):
            return dx + dy
        case Message.Write(text):
            return i32(len(text))


def handle_guarded(msg: Message) -> i32:
    match msg:
        case Message.Quit:
            return 0
        case Message.Move(x, y) if x > y:
            return x - y
        case Message.Move(x, y):
            return y - x
        case Message.Write(text) if len(text) > 2:
            return 9
        case Message.Write(text):
            return i32(len(text))


def make_write() -> Message:
    return Message.Write("xx")


def handle_direct() -> i32:
    match make_write():
        case Message.Quit:
            return 0
        case Message.Move(x, y):
            return x + y
        case Message.Write(text):
            return i32(len(text))


def main() -> i32:
    moved: Message = Message.Move(x=20, y=19)
    return handle(Message.Quit) + handle(moved) + handle_direct() + handle_named(moved) + handle_guarded(moved)
