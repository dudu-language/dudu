from c.path import string.h as c
from cpp.path import imgui.h


def main() -> i32:
    context = ImGui.CreateContext(None)
    if context == None:
        return 1

    version_len = c.strlen(ImGui.GetVersion())
    ImGui.DestroyContext(context)

    if version_len == 0:
        return 2
    return 42
