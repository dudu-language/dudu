from cpp import variant


def variant_index[V...](value: &const[variant[V...]]) -> usize:
    return value.index()


def variant_get_as[T, V...](value: &const[variant[V...]]) -> &const[T]:
    return std.get[T](value)


def main() -> i32:
    value: variant[i32, str] = "ready"
    if variant_index(value) != 1:
        return 1
    return i32(len(variant_get_as[str, i32, str](value))) + 37
