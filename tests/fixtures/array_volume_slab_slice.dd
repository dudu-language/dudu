def sum_view(values: span[i32]) -> i32:
    total: i32 = 0
    for value: i32 in values:
        total += value
    return total


def main() -> i32:
    volume: array[i32][2, 2, 2]
    volume[0, 0, 0] = 1
    volume[0, 0, 1] = 2
    volume[0, 1, 0] = 3
    volume[0, 1, 1] = 4
    volume[1, 0, 0] = 10
    volume[1, 0, 1] = 20
    volume[1, 1, 0] = 30
    volume[1, 1, 1] = 40
    slab: span[i32] = volume[1:, :, :]
    return sum_view(slab)
