class Tensor[T]:
    rows: i32
    cols: i32
    value: T


def filled[T](rows: i32, cols: i32, value: T) -> Tensor[T]:
    return Tensor[T](rows, cols, value)


def expect_runtime_batch(value: Tensor[f32][dyn, 2]) -> i32:
    return value.rows + value.cols


def expect_static_shape(value: Tensor[f32][2, 2]) -> i32:
    return value.rows * value.cols


def main() -> i32:
    shaped: Tensor[f32][dyn, 2] = filled[f32](40, 2, 1.0)
    exact: Tensor[f32][2, 2] = filled[f32](2, 2, 1.0)
    return expect_runtime_batch(shaped) + expect_runtime_batch(exact) + expect_static_shape(exact) - 8
