class TensorView:
    data: &list[f32]
    offset: i32
    rows: i32
    cols: i32
    row_stride: i32
    col_stride: i32

    @operator("[]")
    def at(self, row: i32, col: i32) -> f32:
        index = self.offset + (row * self.row_stride) + (col * self.col_stride)
        return self.data[index]

    @operator("[]=")
    def set_at(self, row: i32, col: i32, value: f32):
        index = self.offset + (row * self.row_stride) + (col * self.col_stride)
        self.data[index] = value


class Tensor:
    rows: i32
    cols: i32
    data: list[f32]

    @operator("[]")
    def at(self, row: i32, col: i32) -> f32:
        return self.data[(row * self.cols) + col]

    @operator("[]=")
    def set_at(self, row: i32, col: i32, value: f32):
        self.data[(row * self.cols) + col] = value

    @operator("[]")
    def row_view(self, row: i32, cols: slice) -> TensorView:
        col_start = slice_start(cols)
        return TensorView(
            self.data,
            (row * self.cols) + col_start,
            1,
            slice_count(cols, self.cols),
            self.cols,
            slice_step(cols),
        )

    @operator("[]")
    def column_view(self, rows: slice, col: i32) -> TensorView:
        row_start = slice_start(rows)
        return TensorView(
            self.data,
            (row_start * self.cols) + col,
            slice_count(rows, self.rows),
            1,
            self.cols * slice_step(rows),
            1,
        )

    @operator("[]")
    def patch_view(self, rows: slice, cols: slice) -> TensorView:
        row_start = slice_start(rows)
        col_start = slice_start(cols)
        return TensorView(
            self.data,
            (row_start * self.cols) + col_start,
            slice_count(rows, self.rows),
            slice_count(cols, self.cols),
            self.cols * slice_step(rows),
            slice_step(cols),
        )


def slice_start(value: slice) -> i32:
    if value.has_start:
        return i32(value.start)
    return 0


def slice_end(value: slice, limit: i32) -> i32:
    if value.has_end:
        return i32(value.end)
    return limit


def slice_step(value: slice) -> i32:
    if value.has_step:
        return i32(value.step)
    return 1


def slice_count(value: slice, limit: i32) -> i32:
    start = slice_start(value)
    stop = slice_end(value, limit)
    step = slice_step(value)
    if stop <= start:
        return 0
    return ((stop - start) + step - 1) / step


def zeros(rows: i32, cols: i32) -> Tensor:
    data: list[f32] = []
    i = 0
    while i < rows * cols:
        data.append(0.0)
        i += 1
    return Tensor(rows, cols, data)


def view_to_tensor(view: TensorView) -> Tensor:
    out = zeros(view.rows, view.cols)
    row = 0
    while row < view.rows:
        col = 0
        while col < view.cols:
            out[row, col] = view[row, col]
            col += 1
        row += 1
    return out


def fill_view(view: &TensorView, value: f32):
    row = 0
    while row < view.rows:
        col = 0
        while col < view.cols:
            view[row, col] = value
            col += 1
        row += 1


def sum_view(view: TensorView) -> f32:
    total: f32 = 0.0
    row = 0
    while row < view.rows:
        col = 0
        while col < view.cols:
            total += view[row, col]
            col += 1
        row += 1
    return total


def filled(rows: i32, cols: i32, value: f32) -> Tensor:
    out = zeros(rows, cols)
    row = 0
    while row < rows:
        col = 0
        while col < cols:
            out[row, col] = value
            col += 1
        row += 1
    return out


def from_2x2(a00: f32, a01: f32, a10: f32, a11: f32) -> Tensor:
    out = zeros(2, 2)
    out[0, 0] = a00
    out[0, 1] = a01
    out[1, 0] = a10
    out[1, 1] = a11
    return out


def from_4x2(
    a00: f32,
    a01: f32,
    a10: f32,
    a11: f32,
    a20: f32,
    a21: f32,
    a30: f32,
    a31: f32,
) -> Tensor:
    out = zeros(4, 2)
    out[0, 0] = a00
    out[0, 1] = a01
    out[1, 0] = a10
    out[1, 1] = a11
    out[2, 0] = a20
    out[2, 1] = a21
    out[3, 0] = a30
    out[3, 1] = a31
    return out


def add(a: Tensor, b: Tensor) -> Tensor:
    out = zeros(a.rows, a.cols)
    row = 0
    while row < a.rows:
        col = 0
        while col < a.cols:
            out[row, col] = a[row, col] + b[row, col]
            col += 1
        row += 1
    return out


def sub(a: Tensor, b: Tensor) -> Tensor:
    out = zeros(a.rows, a.cols)
    row = 0
    while row < a.rows:
        col = 0
        while col < a.cols:
            out[row, col] = a[row, col] - b[row, col]
            col += 1
        row += 1
    return out


def mul(a: Tensor, b: Tensor) -> Tensor:
    out = zeros(a.rows, a.cols)
    row = 0
    while row < a.rows:
        col = 0
        while col < a.cols:
            out[row, col] = a[row, col] * b[row, col]
            col += 1
        row += 1
    return out


def scale(input: Tensor, factor: f32) -> Tensor:
    out = zeros(input.rows, input.cols)
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            out[row, col] = input[row, col] * factor
            col += 1
        row += 1
    return out


def map_values(input: Tensor, fn: fn(f32) -> f32) -> Tensor:
    out = zeros(input.rows, input.cols)
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            out[row, col] = fn(input[row, col])
            col += 1
        row += 1
    return out


def relu_value(value: f32) -> f32:
    if value > 0.0:
        return value
    return 0.0


def relu(input: Tensor) -> Tensor:
    return map_values(input, relu_value)


def transpose(input: Tensor) -> Tensor:
    out = zeros(input.cols, input.rows)
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            out[col, row] = input[row, col]
            col += 1
        row += 1
    return out


def matmul(a: Tensor, b: Tensor) -> Tensor:
    out = zeros(a.rows, b.cols)
    row = 0
    while row < a.rows:
        col = 0
        while col < b.cols:
            acc: f32 = 0.0
            k = 0
            while k < a.cols:
                acc += a[row, k] * b[k, col]
                k += 1
            out[row, col] = acc
            col += 1
        row += 1
    return out


def sum_values(input: Tensor) -> f32:
    total: f32 = 0.0
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            total += input[row, col]
            col += 1
        row += 1
    return total


def mean_values(input: Tensor) -> f32:
    count = input.rows * input.cols
    if count <= 0:
        return 0.0
    return sum_values(input) / f32(count)


def mean_squared_error(prediction: Tensor, target: Tensor) -> f32:
    total: f32 = 0.0
    row = 0
    while row < prediction.rows:
        col = 0
        while col < prediction.cols:
            diff = prediction[row, col] - target[row, col]
            total += diff * diff
            col += 1
        row += 1
    count = prediction.rows * prediction.cols
    if count <= 0:
        return 0.0
    return total / f32(count)


def add_row_bias(input: Tensor, bias: Tensor) -> Tensor:
    out = zeros(input.rows, input.cols)
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            out[row, col] = input[row, col] + bias[0, col]
            col += 1
        row += 1
    return out
