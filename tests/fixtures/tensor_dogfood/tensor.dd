class TensorView:
    data: &list[f32]
    offset: i32
    rows: i32
    cols: i32
    row_stride: i32
    col_stride: i32

    @operator("[]")
    def at(self, row: i32, col: i32) -> f32:
        index = self.offset + (row * self.row_stride) + (col * self.col_stride)
        return self.data[index]

    @operator("[]=")
    def set_at(self, row: i32, col: i32, value: f32):
        index = self.offset + (row * self.row_stride) + (col * self.col_stride)
        self.data[index] = value

    def fill(self, value: f32):
        row = 0
        while row < self.rows:
            col = 0
            while col < self.cols:
                self[row, col] = value
                col += 1
            row += 1

    def sum(self) -> f32:
        total: f32 = 0.0
        row = 0
        while row < self.rows:
            col = 0
            while col < self.cols:
                total += self[row, col]
                col += 1
            row += 1
        return total

    def mean(self) -> f32:
        count = self.rows * self.cols
        if count <= 0:
            return 0.0
        return self.sum() / f32(count)

    def max(self) -> f32:
        if self.rows <= 0 or self.cols <= 0:
            return 0.0
        best = self[0, 0]
        row = 0
        while row < self.rows:
            col = 0
            while col < self.cols:
                value = self[row, col]
                if value > best:
                    best = value
                col += 1
            row += 1
        return best


class Mask:
    data: list[bool]

    @operator("[]")
    def at(self, index: i32) -> bool:
        return self.data[index]

    def count_true(self) -> i32:
        count = 0
        index = 0
        total = i32(len(self.data))
        while index < total:
            if self[index]:
                count += 1
            index += 1
        return count


class MatrixMask:
    rows: i32
    cols: i32
    data: list[bool]

    @operator("[]")
    def at(self, row: i32, col: i32) -> bool:
        return self.data[(row * self.cols) + col]

    def count_true(self) -> i32:
        count = 0
        row = 0
        while row < self.rows:
            col = 0
            while col < self.cols:
                if self[row, col]:
                    count += 1
                col += 1
            row += 1
        return count


class Tensor:
    rows: i32
    cols: i32
    data: list[f32]

    @operator("[]")
    def at(self, row: i32, col: i32) -> f32:
        return self.data[(row * self.cols) + col]

    @operator("[]=")
    def set_at(self, row: i32, col: i32, value: f32):
        self.data[(row * self.cols) + col] = value

    @operator("[]")
    def row_view(self, row: i32, cols: slice) -> TensorView:
        col_start = slice_start(cols)
        return TensorView(
            self.data,
            (row * self.cols) + col_start,
            1,
            slice_count(cols, self.cols),
            self.cols,
            slice_step(cols),
        )

    @operator("[]")
    def column_view(self, rows: slice, col: i32) -> TensorView:
        row_start = slice_start(rows)
        return TensorView(
            self.data,
            (row_start * self.cols) + col,
            slice_count(rows, self.rows),
            1,
            self.cols * slice_step(rows),
            1,
        )

    @operator("[]")
    def patch_view(self, rows: slice, cols: slice) -> TensorView:
        row_start = slice_start(rows)
        col_start = slice_start(cols)
        return TensorView(
            self.data,
            (row_start * self.cols) + col_start,
            slice_count(rows, self.rows),
            slice_count(cols, self.cols),
            self.cols * slice_step(rows),
            slice_step(cols),
        )

    @operator("[]")
    def masked_rows(self, mask: Mask, cols: slice) -> Tensor:
        out = zeros(mask.count_true(), slice_count(cols, self.cols))
        out_row = 0
        row = 0
        while row < self.rows:
            if mask[row]:
                col = 0
                col_start = slice_start(cols)
                while col < out.cols:
                    out[out_row, col] = self[row, col_start + col]
                    col += 1
                out_row += 1
            row += 1
        return out

    @operator("[]=")
    def set_masked_rows(self, mask: Mask, cols: slice, value: Tensor):
        value_row = 0
        row = 0
        while row < self.rows:
            if mask[row]:
                col = 0
                col_start = slice_start(cols)
                while col < value.cols:
                    self[row, col_start + col] = value[value_row, col]
                    col += 1
                value_row += 1
            row += 1

    @operator("[]")
    def masked_elements(self, mask: MatrixMask) -> Tensor:
        out = zeros(mask.count_true(), 1)
        out_row = 0
        row = 0
        while row < self.rows:
            col = 0
            while col < self.cols:
                if mask[row, col]:
                    out[out_row, 0] = self[row, col]
                    out_row += 1
                col += 1
            row += 1
        return out

    @operator("[]=")
    def set_masked_elements_scalar(self, mask: MatrixMask, value: f32):
        row = 0
        while row < self.rows:
            col = 0
            while col < self.cols:
                if mask[row, col]:
                    self[row, col] = value
                col += 1
            row += 1

    @operator("[]=")
    def set_masked_elements(self, mask: MatrixMask, value: Tensor):
        value_row = 0
        row = 0
        while row < self.rows:
            col = 0
            while col < self.cols:
                if mask[row, col]:
                    self[row, col] = value[value_row, 0]
                    value_row += 1
                col += 1
            row += 1


def slice_start(value: slice) -> i32:
    if value.has_start:
        return i32(value.start)
    return 0


def slice_end(value: slice, limit: i32) -> i32:
    if value.has_end:
        return i32(value.end)
    return limit


def slice_step(value: slice) -> i32:
    if value.has_step:
        return i32(value.step)
    return 1


def slice_count(value: slice, limit: i32) -> i32:
    start = slice_start(value)
    stop = slice_end(value, limit)
    step = slice_step(value)
    if stop <= start:
        return 0
    return ((stop - start) + step - 1) / step


def zeros(rows: i32, cols: i32) -> Tensor:
    data: list[f32] = []
    i = 0
    while i < rows * cols:
        data.append(0.0)
        i += 1
    return Tensor(rows, cols, data)


def view_to_tensor(view: TensorView) -> Tensor:
    out = zeros(view.rows, view.cols)
    row = 0
    while row < view.rows:
        col = 0
        while col < view.cols:
            out[row, col] = view[row, col]
            col += 1
        row += 1
    return out


def fill_view(view: &TensorView, value: f32):
    view.fill(value)


def sum_view(view: TensorView) -> f32:
    return view.sum()


def filled(rows: i32, cols: i32, value: f32) -> Tensor:
    out = zeros(rows, cols)
    row = 0
    while row < rows:
        col = 0
        while col < cols:
            out[row, col] = value
            col += 1
        row += 1
    return out


def from_2x2(a00: f32, a01: f32, a10: f32, a11: f32) -> Tensor:
    out = zeros(2, 2)
    out[0, 0] = a00
    out[0, 1] = a01
    out[1, 0] = a10
    out[1, 1] = a11
    return out


def from_4x2(
    a00: f32,
    a01: f32,
    a10: f32,
    a11: f32,
    a20: f32,
    a21: f32,
    a30: f32,
    a31: f32,
) -> Tensor:
    out = zeros(4, 2)
    out[0, 0] = a00
    out[0, 1] = a01
    out[1, 0] = a10
    out[1, 1] = a11
    out[2, 0] = a20
    out[2, 1] = a21
    out[3, 0] = a30
    out[3, 1] = a31
    return out


def row_sum_mask(input: Tensor, threshold: f32) -> Mask:
    data: list[bool] = []
    row = 0
    while row < input.rows:
        total: f32 = 0.0
        col = 0
        while col < input.cols:
            total += input[row, col]
            col += 1
        data.append(total > threshold)
        row += 1
    return Mask(data)


def greater_than(input: Tensor, threshold: f32) -> MatrixMask:
    data: list[bool] = []
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            data.append(input[row, col] > threshold)
            col += 1
        row += 1
    return MatrixMask(input.rows, input.cols, data)


def add(a: Tensor, b: Tensor) -> Tensor:
    out = zeros(a.rows, a.cols)
    row = 0
    while row < a.rows:
        col = 0
        while col < a.cols:
            out[row, col] = a[row, col] + b[row, col]
            col += 1
        row += 1
    return out


def sub(a: Tensor, b: Tensor) -> Tensor:
    out = zeros(a.rows, a.cols)
    row = 0
    while row < a.rows:
        col = 0
        while col < a.cols:
            out[row, col] = a[row, col] - b[row, col]
            col += 1
        row += 1
    return out


def mul(a: Tensor, b: Tensor) -> Tensor:
    out = zeros(a.rows, a.cols)
    row = 0
    while row < a.rows:
        col = 0
        while col < a.cols:
            out[row, col] = a[row, col] * b[row, col]
            col += 1
        row += 1
    return out


def scale(input: Tensor, factor: f32) -> Tensor:
    out = zeros(input.rows, input.cols)
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            out[row, col] = input[row, col] * factor
            col += 1
        row += 1
    return out


def map_values(input: Tensor, fn: fn(f32) -> f32) -> Tensor:
    out = zeros(input.rows, input.cols)
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            out[row, col] = fn(input[row, col])
            col += 1
        row += 1
    return out


def relu_value(value: f32) -> f32:
    if value > 0.0:
        return value
    return 0.0


def relu(input: Tensor) -> Tensor:
    return map_values(input, relu_value)


def leaky_relu_value(value: f32) -> f32:
    if value > 0.0:
        return value
    return value * 0.01


def leaky_relu(input: Tensor) -> Tensor:
    return map_values(input, leaky_relu_value)


def clamp_value(value: f32, low: f32, high: f32) -> f32:
    if value < low:
        return low
    if value > high:
        return high
    return value


def clamp(input: Tensor, low: f32, high: f32) -> Tensor:
    out = zeros(input.rows, input.cols)
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            out[row, col] = clamp_value(input[row, col], low, high)
            col += 1
        row += 1
    return out


def threshold(input: Tensor, cutoff: f32) -> Tensor:
    out = zeros(input.rows, input.cols)
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            if input[row, col] >= cutoff:
                out[row, col] = 1.0
            else:
                out[row, col] = 0.0
            col += 1
        row += 1
    return out


def transpose(input: Tensor) -> Tensor:
    out = zeros(input.cols, input.rows)
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            out[col, row] = input[row, col]
            col += 1
        row += 1
    return out


def matmul(a: Tensor, b: Tensor) -> Tensor:
    out = zeros(a.rows, b.cols)
    row = 0
    while row < a.rows:
        col = 0
        while col < b.cols:
            acc: f32 = 0.0
            k = 0
            while k < a.cols:
                acc += a[row, k] * b[k, col]
                k += 1
            out[row, col] = acc
            col += 1
        row += 1
    return out


def sum_values(input: Tensor) -> f32:
    total: f32 = 0.0
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            total += input[row, col]
            col += 1
        row += 1
    return total


def mean_values(input: Tensor) -> f32:
    count = input.rows * input.cols
    if count <= 0:
        return 0.0
    return sum_values(input) / f32(count)


def mean_squared_error(prediction: Tensor, target: Tensor) -> f32:
    total: f32 = 0.0
    row = 0
    while row < prediction.rows:
        col = 0
        while col < prediction.cols:
            diff = prediction[row, col] - target[row, col]
            total += diff * diff
            col += 1
        row += 1
    count = prediction.rows * prediction.cols
    if count <= 0:
        return 0.0
    return total / f32(count)


def mean_absolute_error(prediction: Tensor, target: Tensor) -> f32:
    total: f32 = 0.0
    row = 0
    while row < prediction.rows:
        col = 0
        while col < prediction.cols:
            diff = prediction[row, col] - target[row, col]
            if diff < 0.0:
                diff = 0.0 - diff
            total += diff
            col += 1
        row += 1
    count = prediction.rows * prediction.cols
    if count <= 0:
        return 0.0
    return total / f32(count)


def binary_accuracy(prediction: Tensor, target: Tensor, cutoff: f32) -> f32:
    correct = 0
    total = prediction.rows * prediction.cols
    row = 0
    while row < prediction.rows:
        col = 0
        while col < prediction.cols:
            predicted = 0
            expected = 0
            if prediction[row, col] >= cutoff:
                predicted = 1
            if target[row, col] >= cutoff:
                expected = 1
            if predicted == expected:
                correct += 1
            col += 1
        row += 1
    if total <= 0:
        return 0.0
    return f32(correct) / f32(total)


def add_row_bias(input: Tensor, bias: Tensor) -> Tensor:
    out = zeros(input.rows, input.cols)
    row = 0
    while row < input.rows:
        col = 0
        while col < input.cols:
            out[row, col] = input[row, col] + bias[0, col]
            col += 1
        row += 1
    return out
