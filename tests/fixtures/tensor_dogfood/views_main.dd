from tensor import Tensor
from tensor import zeros


def fill_grid(t: &Tensor):
    t[0, 0] = 1.0
    t[0, 1] = 2.0
    t[0, 2] = 3.0
    t[0, 3] = 4.0
    t[1, 0] = 5.0
    t[1, 1] = 6.0
    t[1, 2] = 7.0
    t[1, 3] = 8.0
    t[2, 0] = 9.0
    t[2, 1] = 10.0
    t[2, 2] = 11.0
    t[2, 3] = 12.0


def main() -> i32:
    t = zeros(3, 4)
    fill_grid(t)

    row = t[1, :]
    col = t[:, 2]
    patch = t[1:3, 1:4:2]

    row_next: f32 = row[0, 0] + 6.0
    row[0, 0] = row_next
    col_next: f32 = col[2, 0] + 4.0
    col[2, 0] = col_next
    patch_next: f32 = patch[1, 1] + 4.0
    patch[1, 1] = patch_next

    return i32(t[1, 0] + t[2, 2] + t[2, 3])
