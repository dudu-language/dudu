import c "pthread.h"


class Counter:
    mutex: pthread_mutex_t
    value: i32


def thread_main(user_data: *void) -> *void:
    counter: *Counter = *Counter(user_data)
    pthread_mutex_lock(&counter.mutex)
    counter.value += 21
    pthread_mutex_unlock(&counter.mutex)
    return None


def main() -> i32:
    counter: Counter
    counter.value = 0
    pthread_mutex_init(&counter.mutex, None)

    thread: pthread_t
    err = pthread_create(&thread, None, thread_main, &counter)
    if err != 0:
        pthread_mutex_destroy(&counter.mutex)
        return 1

    pthread_join(thread, None)
    pthread_mutex_lock(&counter.mutex)
    counter.value += 21
    total = counter.value
    pthread_mutex_unlock(&counter.mutex)
    pthread_mutex_destroy(&counter.mutex)
    return total
