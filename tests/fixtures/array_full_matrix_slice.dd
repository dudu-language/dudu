def sum_view(values: array_view[i32]) -> i32:
    total: i32 = 0
    for value: i32 in values:
        total += value
    return total


def main() -> i32:
    matrix: array[i32] = [
        [1, 2],
        [10, 20],
        [3, 6],
    ]
    all_values: array_view[i32] = matrix[:, :]
    return sum_view(all_values)
