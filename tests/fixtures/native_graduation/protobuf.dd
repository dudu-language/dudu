from cpp.path import generated/player.pb.h
from cpp import string


def main() -> i32:
    player = dudu_compat.Player()
    player.set_name("dudu")
    player.set_score(40)
    player.add_samples(1)
    player.add_samples(2)

    encoded: std.string = player.SerializeAsString()
    decoded = dudu_compat.Player()
    if not decoded.ParseFromString(encoded):
        return 1
    if decoded.name() != "dudu":
        return 2
    if decoded.score() + decoded.samples(1) != 42:
        return 3
    if decoded.samples_size() != 2:
        return 4
    return 0
