from cpp import range/v3/numeric/accumulate.hpp
from cpp import range/v3/view/filter.hpp
from cpp import range/v3/view/iota.hpp
from cpp import range/v3/view/transform.hpp


def square(value: i32) -> i32:
    return value * value


def is_even(value: i32) -> bool:
    return value % 2 == 0


def main() -> i32:
    values = ranges.views.ints(1, 7) | ranges.views.transform(square)
    evens = values | ranges.views.filter(is_even)
    total = ranges.accumulate(evens, 0)
    if total != 56:
        return 1
    return 0
