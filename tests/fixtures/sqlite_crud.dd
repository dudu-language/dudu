import c "sqlite3.h" as sqlite
from cpp import string


class Todo:
    id: i64
    title: str
    done: bool


enum DbError:
    OpenFailed
    QueryFailed
    NotFound


def fetch_todo(db: *struct sqlite3, todo_id: i64) -> Result[Todo, DbError]:
    query: str = "select id, title, done from todos where id = ?"
    stmt: *struct sqlite3_stmt = None

    if sqlite.sqlite3_prepare_v2(db, query.c_str(), -1, &stmt, None) != sqlite.SQLITE_OK:
        return Err(DbError.QueryFailed)

    sqlite.sqlite3_bind_int64(stmt, 1, todo_id)
    if sqlite.sqlite3_step(stmt) != sqlite.SQLITE_ROW:
        sqlite.sqlite3_finalize(stmt)
        return Err(DbError.NotFound)

    todo = Todo(
        id=sqlite.sqlite3_column_int64(stmt, 0),
        title=std.string(cstr(sqlite.sqlite3_column_text(stmt, 1))),
        done=sqlite.sqlite3_column_int(stmt, 2) != 0,
    )
    sqlite.sqlite3_finalize(stmt)
    return Ok(todo)


def main() -> i32:
    db: *struct sqlite3 = None
    if sqlite.sqlite3_open(":memory:", &db) != sqlite.SQLITE_OK:
        return 1

    create_sql: str = "create table todos(id integer primary key, title text, done integer)"
    insert_sql: str = "insert into todos(id, title, done) values(42, 'ship dudu', 1)"
    if sqlite.sqlite3_exec(db, create_sql.c_str(), None, None, None) != sqlite.SQLITE_OK:
        sqlite.sqlite3_close(db)
        return 2
    if sqlite.sqlite3_exec(db, insert_sql.c_str(), None, None, None) != sqlite.SQLITE_OK:
        sqlite.sqlite3_close(db)
        return 3

    result = fetch_todo(db, 42)
    sqlite.sqlite3_close(db)
    if not result.ok:
        return 4
    if result.value.title == "ship dudu" and result.value.done:
        return i32(result.value.id)
    return 5
