def choose(flag: bool) -> Result[i32, i32]:
    if flag:
        return Ok(40)
    return Err(7)


def choose_option(flag: bool) -> Option[i32]:
    if flag:
        return 2
    return None


def main() -> i32:
    result = choose(True)
    empty: Option[i32] = None
    value = choose_option(True)
    value = None
    value = 2

    if result.ok and not empty.has_value() and not choose_option(False).has_value():
        return result.value + value.value()
    return 1
