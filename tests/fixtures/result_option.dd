def choose(flag: bool) -> Result[i32, i32]:
    if flag:
        return Ok(40)
    return Err(7)


def choose_option(flag: bool) -> Option[i32]:
    if flag:
        return 2
    return None


def unwrap_result(result: Result[i32, i32]) -> i32:
    match result:
        case Ok(value):
            return value
        case Err(error):
            return error


def unwrap_option(value: Option[i32], fallback: i32) -> i32:
    match value:
        case Some(inner):
            return inner
        case None:
            return fallback


def main() -> i32:
    result = choose(True)
    value = choose_option(True)
    return unwrap_result(result) + unwrap_option(value, 0)
