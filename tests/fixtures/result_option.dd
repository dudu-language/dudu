def choose(flag: bool) -> Result[i32, i32]:
    if flag:
        return Ok(40)
    return Err(7)


def main() -> i32:
    result = choose(True)
    empty: Option[i32] = None
    value: Option[i32] = 2
    value = None
    value = 2

    if result.ok and not empty.has_value():
        return result.value + value.value()
    return 1
