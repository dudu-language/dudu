from cpp.path import native_headers/string_reference_sink.hpp


def write_value[Writer](value: &const[str], output: &Writer) -> bool:
    return output.write(value)


def main() -> i32:
    output = string_reference_sink.Sink()
    value = "dudu"
    if not write_value(value, output):
        return 1
    return 0
