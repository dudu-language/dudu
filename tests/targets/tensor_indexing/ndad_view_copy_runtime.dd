# Target: basic direct tensor indexing is view-like, while advanced indexing
# materializes copy-like tensor results through ordinary library overloads.

from ndad import Tensor
from ndad import arange
from ndad import zeros


def main() -> i32:
    x: Tensor[i32][3, 4] = zeros[i32](3, 4)
    index = 0
    while index < 12:
        x.data[index] = index
        index += 1

    row = x[1, :]
    row.fill(5)
    if x.data[4] != 5:
        return 1
    if x.data[7] != 5:
        return 2

    patch = x[1:, 1:3]
    copied = patch.to_tensor()
    copied.data[0] = -1
    if x.data[5] != 5:
        return 3

    ids = arange(2)
    gathered = x[ids, :]
    gathered.data[0] = 123
    if x.data[0] == 123:
        return 4

    return 0
