# Target: parser/AST preserves Python-shaped index items and source ranges.

class Tensor:
    marker: i32


def main() -> i32:
    ids: list[i32] = [0, 2, 4]
    mask: list[bool] = [True, False, True]
    x = Tensor(1)

    row = x[:, ids, None, ...]
    col = x[1:8:2, mask, None]
    tail = x[..., -1]
    expanded = x[None, :, None]

    return x.marker
