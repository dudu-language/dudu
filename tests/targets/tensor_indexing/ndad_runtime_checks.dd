# Target: ndad indexing behavior is real at runtime, not just emit-valid.

from ndad import Tensor
from ndad import arange
from ndad import array
from ndad import zeros


def main() -> i32:
    rank5: Tensor[i32][2, 1, 2, 1, 2] = zeros[i32](2, 1, 2, 1, 2)
    if rank5.shape[0] != 2:
        return 51
    if rank5.shape[2] != 2:
        return 52
    if rank5.shape[4] != 2:
        return 53
    if len(rank5.data) != 8:
        return 54

    tensor: Tensor[i32][2, 3, 4] = zeros[i32](2, 3, 4)
    fill_index = 0
    fill_total = i32(len(tensor.data))
    while fill_index < fill_total:
        tensor.data[fill_index] = fill_index
        fill_index += 1

    if tensor.strides[0] != 12:
        return 1
    if tensor.strides[1] != 4:
        return 2
    if tensor.strides[2] != 1:
        return 3

    row = tensor[1, :, 2]
    if row.shape[0] != 3:
        return 4
    if row.strides[0] != 4:
        return 5
    if row.offset != 14:
        return 6

    last = tensor[..., -1]
    if last.shape[0] != 2:
        return 7
    if last.shape[1] != 3:
        return 8
    if last.offset != 3:
        return 9

    expanded = tensor[None, :, 1, :]
    if expanded.shape[0] != 1:
        return 10
    if expanded.shape[1] != 2:
        return 11
    if expanded.shape[2] != 4:
        return 12
    if expanded.offset != 4:
        return 13

    ids = arange(2)
    gathered = tensor[ids, :, ids]
    if gathered.shape[0] != 2:
        return 14
    if gathered.shape[1] != 3:
        return 15
    if gathered.data[0] != 0:
        return 16
    if gathered.data[1] != 4:
        return 17
    if gathered.data[2] != 8:
        return 18
    if gathered.data[3] != 13:
        return 19
    if gathered.data[4] != 17:
        return 20
    if gathered.data[5] != 21:
        return 21

    cart = tensor.cartesian[ids, :, ids]
    if cart.shape[0] != 2:
        return 22
    if cart.shape[1] != 3:
        return 23
    if cart.shape[2] != 2:
        return 24
    if cart.data[0] != 0:
        return 25
    if cart.data[1] != 1:
        return 26
    if cart.data[2] != 4:
        return 27
    if cart.data[3] != 5:
        return 28

    writable: Tensor[i32][2, 3] = zeros[i32](2, 3)
    writable[1, 2] = 7
    if writable.data[5] != 7:
        return 29

    writable[:, 2] = 9
    if writable.data[2] != 9:
        return 30
    if writable.data[5] != 9:
        return 31

    column = array[i32]([0, 1])
    writable[:, 1] = column
    if writable.data[1] != 0:
        return 32
    if writable.data[4] != 1:
        return 33

    mask_source = zeros[i32](4)
    mask_source.data[1] = -1
    mask = mask_source < 0
    if mask.count_true() != 1:
        return 34

    values = array[i32]([10, 20, 30, 40])
    masked = values[mask]
    if masked.shape[0] != 1:
        return 35
    if masked.data[0] != 20:
        return 36

    values[mask] = 99
    if values.data[0] != 10:
        return 37
    if values.data[1] != 99:
        return 38
    if values.data[2] != 30:
        return 39
    if values.data[3] != 40:
        return 40

    matrix: Tensor[i32][3, 2] = zeros[i32](3, 2)
    matrix_index = 0
    matrix_total = i32(len(matrix.data))
    while matrix_index < matrix_total:
        matrix.data[matrix_index] = matrix_index
        matrix_index += 1

    row_mask = array[i32]([0, -1, 0]) < 0
    masked_rows = matrix[row_mask, :]
    if masked_rows.shape[0] != 1:
        return 41
    if masked_rows.shape[1] != 2:
        return 42
    if masked_rows.data[0] != 2:
        return 43
    if masked_rows.data[1] != 3:
        return 44

    matrix[row_mask, :] = 8
    if matrix.data[0] != 0:
        return 45
    if matrix.data[1] != 1:
        return 46
    if matrix.data[2] != 8:
        return 47
    if matrix.data[3] != 8:
        return 48
    if matrix.data[4] != 4:
        return 49
    if matrix.data[5] != 5:
        return 50

    return 0
