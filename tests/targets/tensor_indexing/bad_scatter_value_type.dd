# Target diagnostic: []= must validate the assigned scatter value type.

from ndad import Tensor
from ndad import BoolMask
from ndad import zeros


def main() -> i32:
    x: Tensor[f32][32, 784] = zeros[f32](32, 784)
    mask: BoolMask = x[:, 0] > 0.0
    wrong: Tensor[i32][dyn, 784] = zeros[i32](4, 784)
    x[mask, :] = wrong
    return 1
