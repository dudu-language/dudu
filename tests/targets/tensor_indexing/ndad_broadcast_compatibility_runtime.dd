# Target: broadcasting compatibility is library policy, not compiler policy.

from ndad import Tensor
from ndad import can_broadcast
from ndad import zeros


def main() -> i32:
    matrix: Tensor[i32][2, 3] = zeros[i32](2, 3)
    row: Tensor[i32][3] = zeros[i32](3)
    column: Tensor[i32][2, 1] = zeros[i32](2, 1)
    bad: Tensor[i32][2, 4] = zeros[i32](2, 4)
    high_rank: Tensor[i32][2, 1, 3] = zeros[i32](2, 1, 3)
    high_rank_bias: Tensor[i32][1, 4, 3] = zeros[i32](1, 4, 3)

    if not can_broadcast(matrix, row):
        return 1
    if not can_broadcast(matrix, column):
        return 2
    if not can_broadcast(high_rank, high_rank_bias):
        return 3
    if can_broadcast(matrix, bad):
        return 4

    return 0
