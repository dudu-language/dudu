# Target: ordinary containers keep simple fixed-arity [] and []= hooks.

class Grid:
    width: i32
    data: list[i32]

    @operator("[]")
    def at(self, y: i32, x: i32) -> i32:
        return self.data[(y * self.width) + x]

    @operator("[]=")
    def set_at(self, y: i32, x: i32, value: i32):
        self.data[(y * self.width) + x] = value


def main() -> i32:
    grid = Grid(3, [1, 2, 3, 4, 5, 6])
    grid[1, 1] = 40
    return grid[0, 0] + grid[1, 1] + grid[1, 2] - 5
