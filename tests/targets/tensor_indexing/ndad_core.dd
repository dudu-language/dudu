# Target: ndad core storage is rank-independent: shape, strides, and offset.

from ndad import Tensor
from ndad import TensorView
from ndad import zeros


def main() -> i32:
    tensor: Tensor[i32][2, 3] = zeros[i32](2, 3)
    view = TensorView[i32](tensor.data, tensor.shape, tensor.strides, tensor.offset)
    selected = view[:, 1]

    return i32(tensor.shape[0] + tensor.shape[1] + tensor.strides[0] + selected.offset)
