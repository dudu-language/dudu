from cpp.path import ndad_native.hpp as ndad_native

class BoolMask:
    data: list[bool]

    @operator("[]")
    def at(self, index: i32) -> bool:
        return self.data[index]

    def count_true(self) -> i32:
        count = 0
        index = 0
        total = i32(len(self.data))
        while index < total:
            if self.data[index]:
                count += 1
            index += 1
        return count


class TensorSelection[T, Idx...]:
    value: T
    shape: list[i64]


class TensorAssignable[T, Idx...]:
    value: T
    shape: list[i64]


class CartesianIndexer[T]:
    data: *list[T]
    shape: list[i64]
    strides: list[i64]
    offset: i64

    @operator("[]")
    def at[Idx...](self, *idx: Idx) -> Tensor[T]:
        plan = cpp("ndad::cartesian_index_plan(self.shape, self.strides, self.offset, idx...)")
        data: list[T] = cpp("ndad::result_data((*self.data), plan)")
        shape: list[i64] = cpp("plan.shape")
        strides: list[i64] = cpp("ndad::result_strides(plan)")
        offset: i64 = cpp("ndad::result_offset(plan)")
        return tensor_from_data_shape_strides[T](data, shape, strides, offset)


class TensorView[T]:
    data: &list[T]
    shape: list[i64]
    strides: list[i64]
    offset: i64

    @operator("[]")
    def at_basic(self, *idx: basic_index) -> TensorView[T]:
        plan = cpp("ndad::index_plan(self.shape, self.strides, self.offset, idx...)")
        shape: list[i64] = cpp("plan.shape")
        strides: list[i64] = cpp("ndad::result_strides(plan)")
        offset: i64 = cpp("ndad::result_offset(plan)")
        return TensorView[T](self.data, shape, strides, offset)

    @operator("[]")
    def at[Idx...](self, *idx: Idx) -> Tensor[T]:
        plan = cpp("ndad::index_plan(self.shape, self.strides, self.offset, idx...)")
        data: list[T] = cpp("ndad::result_data(self.data, plan)")
        shape: list[i64] = cpp("plan.shape")
        strides: list[i64] = cpp("ndad::result_strides(plan)")
        offset: i64 = cpp("ndad::result_offset(plan)")
        return tensor_from_data_shape_strides[T](data, shape, strides, offset)

    def fill(self, value: T):
        cpp("ndad::assign_scalar(self.data, self.shape, self.strides, self.offset, value);")

    def count(self) -> i64:
        return element_count(self.shape)

    def sum(self) -> T:
        return cpp("ndad::sum_value(self.data, self.shape, self.strides, self.offset)")

    def mean(self) -> f64:
        return cpp("ndad::mean_value(self.data, self.shape, self.strides, self.offset)")

    def to_tensor(self) -> Tensor[T]:
        data: list[T] = cpp("ndad::materialize_view(self.data, self.shape, self.strides, self.offset)")
        return tensor_from_data_shape[T](data, self.shape)

    def flatten(self) -> Tensor[T]:
        data: list[T] = cpp("ndad::materialize_view(self.data, self.shape, self.strides, self.offset)")
        shape: list[i64] = []
        shape.append(i64(len(data)))
        return tensor_from_data_shape[T](data, shape)

    def reshape[Dims...](self, *dims: Dims) -> Tensor[T]:
        data: list[T] = cpp("ndad::materialize_view(self.data, self.shape, self.strides, self.offset)")
        shape: list[i64] = cpp("ndad::shape_from_dims(dims...)")
        if element_count(shape) != i64(len(data)):
            cpp("""throw std::runtime_error("reshape element count mismatch");""")
        return tensor_from_data_shape[T](data, shape)

    def item(self) -> T:
        return cpp("ndad::item_value(self.data, self.shape, self.strides, self.offset)")

    @operator("+")
    def add_scalar(self: &TensorView[T], value: T) -> Tensor[T]:
        return self.to_tensor() + value

    @operator("-")
    def sub_scalar(self: &TensorView[T], value: T) -> Tensor[T]:
        return self.to_tensor() - value

    @operator("*")
    def mul_scalar(self: &TensorView[T], value: T) -> Tensor[T]:
        return self.to_tensor() * value

    @operator(">")
    def greater_than(self, value: T) -> BoolMask:
        values: list[bool] = []
        tensor = self.to_tensor()
        total = i32(len(tensor.data))
        index = 0
        while index < total:
            values.append(tensor.data[index] > value)
            index += 1
        return BoolMask(values)

    @operator("<")
    def less_than(self, value: T) -> BoolMask:
        values: list[bool] = []
        tensor = self.to_tensor()
        total = i32(len(tensor.data))
        index = 0
        while index < total:
            values.append(tensor.data[index] < value)
            index += 1
        return BoolMask(values)


class Tensor[T]:
    data: list[T]
    shape: list[i64]
    strides: list[i64]
    offset: i64
    cartesian: CartesianIndexer[T]

    @operator("[]")
    def at_basic(self, *idx: basic_index) -> TensorView[T]:
        plan = cpp("ndad::index_plan(self.shape, self.strides, self.offset, idx...)")
        shape: list[i64] = cpp("plan.shape")
        strides: list[i64] = cpp("ndad::result_strides(plan)")
        offset: i64 = cpp("ndad::result_offset(plan)")
        return TensorView[T](self.data, shape, strides, offset)

    @operator("[]")
    def at[Idx...](self, *idx: Idx) -> Tensor[T]:
        plan = cpp("ndad::index_plan(self.shape, self.strides, self.offset, idx...)")
        data: list[T] = cpp("ndad::result_data(self.data, plan)")
        shape: list[i64] = cpp("plan.shape")
        strides: list[i64] = cpp("ndad::result_strides(plan)")
        offset: i64 = cpp("ndad::result_offset(plan)")
        return tensor_from_data_shape_strides[T](data, shape, strides, offset)

    def item(self) -> T:
        return cpp("ndad::item_value(self.data, self.shape, self.strides, self.offset)")

    def count(self) -> i64:
        return element_count(self.shape)

    def sum(self) -> T:
        return cpp("ndad::sum_value(self.data, self.shape, self.strides, self.offset)")

    def mean(self) -> f64:
        return cpp("ndad::mean_value(self.data, self.shape, self.strides, self.offset)")

    def to_tensor(self) -> Tensor[T]:
        data: list[T] = cpp("ndad::materialize_view(self.data, self.shape, self.strides, self.offset)")
        return tensor_from_data_shape[T](data, self.shape)

    def flatten(self) -> Tensor[T]:
        data: list[T] = cpp("ndad::materialize_view(self.data, self.shape, self.strides, self.offset)")
        shape: list[i64] = []
        shape.append(i64(len(data)))
        return tensor_from_data_shape[T](data, shape)

    def reshape[Dims...](self, *dims: Dims) -> Tensor[T]:
        data: list[T] = cpp("ndad::materialize_view(self.data, self.shape, self.strides, self.offset)")
        shape: list[i64] = cpp("ndad::shape_from_dims(dims...)")
        if element_count(shape) != i64(len(data)):
            cpp("""throw std::runtime_error("reshape element count mismatch");""")
        return tensor_from_data_shape[T](data, shape)

    @operator("[]=")
    def set_tensor[Idx...](self, *idx: Idx, value: Tensor[T]):
        cpp("""
ndad::assign_tensor(self.data, self.shape, self.strides, self.offset,
                    value.data, value.shape, value.strides, value.offset, idx...);
""")

    @operator("[]=")
    def set_scalar[Idx...](self, *idx: Idx, value: T):
        cpp("ndad::assign_scalar(self.data, self.shape, self.strides, self.offset, value, idx...);")

    @operator("+")
    def add[Dims...](self: &Tensor[T][Dims...], other: Tensor[T]) -> Tensor[T][Dims...]:
        shape: list[i64] = cpp("ndad::left_broadcast_shape(self.shape, other.shape)")
        data: list[T] = cpp("ndad::binary_add_data(self.data, self.shape, self.strides, self.offset, other.data, other.shape, other.strides, other.offset)")
        return tensor_from_data_shape[T](data, shape)

    @operator("+")
    def add_view[Dims...](self: &Tensor[T][Dims...], other: TensorView[T]) -> Tensor[T][Dims...]:
        other_tensor = other.to_tensor()
        shape: list[i64] = cpp("ndad::left_broadcast_shape(self.shape, other_tensor.shape)")
        data: list[T] = cpp("ndad::binary_add_data(self.data, self.shape, self.strides, self.offset, other_tensor.data, other_tensor.shape, other_tensor.strides, other_tensor.offset)")
        return tensor_from_data_shape[T](data, shape)

    @operator("+")
    def add_scalar(self: &Tensor[T], value: T) -> Tensor[T]:
        data: list[T] = []
        index = 0
        tensor = self.to_tensor()
        total = i32(len(tensor.data))
        while index < total:
            data.append(tensor.data[index] + value)
            index += 1
        return tensor_from_data_shape[T](data, self.shape)

    @operator("-")
    def sub[Dims...](self: &Tensor[T][Dims...], other: Tensor[T]) -> Tensor[T][Dims...]:
        shape: list[i64] = cpp("ndad::left_broadcast_shape(self.shape, other.shape)")
        data: list[T] = cpp("ndad::binary_sub_data(self.data, self.shape, self.strides, self.offset, other.data, other.shape, other.strides, other.offset)")
        return tensor_from_data_shape[T](data, shape)

    @operator("-")
    def sub_view[Dims...](self: &Tensor[T][Dims...], other: TensorView[T]) -> Tensor[T][Dims...]:
        other_tensor = other.to_tensor()
        shape: list[i64] = cpp("ndad::left_broadcast_shape(self.shape, other_tensor.shape)")
        data: list[T] = cpp("ndad::binary_sub_data(self.data, self.shape, self.strides, self.offset, other_tensor.data, other_tensor.shape, other_tensor.strides, other_tensor.offset)")
        return tensor_from_data_shape[T](data, shape)

    @operator("-")
    def sub_scalar(self: &Tensor[T], value: T) -> Tensor[T]:
        data: list[T] = []
        index = 0
        tensor = self.to_tensor()
        total = i32(len(tensor.data))
        while index < total:
            data.append(tensor.data[index] - value)
            index += 1
        return tensor_from_data_shape[T](data, self.shape)

    @operator("*")
    def mul[Dims...](self: &Tensor[T][Dims...], other: Tensor[T]) -> Tensor[T][Dims...]:
        shape: list[i64] = cpp("ndad::left_broadcast_shape(self.shape, other.shape)")
        data: list[T] = cpp("ndad::binary_mul_data(self.data, self.shape, self.strides, self.offset, other.data, other.shape, other.strides, other.offset)")
        return tensor_from_data_shape[T](data, shape)

    @operator("*")
    def mul_view[Dims...](self: &Tensor[T][Dims...], other: TensorView[T]) -> Tensor[T][Dims...]:
        other_tensor = other.to_tensor()
        shape: list[i64] = cpp("ndad::left_broadcast_shape(self.shape, other_tensor.shape)")
        data: list[T] = cpp("ndad::binary_mul_data(self.data, self.shape, self.strides, self.offset, other_tensor.data, other_tensor.shape, other_tensor.strides, other_tensor.offset)")
        return tensor_from_data_shape[T](data, shape)

    @operator("*")
    def mul_scalar(self: &Tensor[T], value: T) -> Tensor[T]:
        data: list[T] = []
        index = 0
        tensor = self.to_tensor()
        total = i32(len(tensor.data))
        while index < total:
            data.append(tensor.data[index] * value)
            index += 1
        return tensor_from_data_shape[T](data, self.shape)

    @operator(">")
    def greater_than(self, value: T) -> BoolMask:
        values: list[bool] = []
        total = i32(len(self.data))
        index = 0
        while index < total:
            values.append(self.data[index] > value)
            index += 1
        return BoolMask(values)

    @operator("<")
    def less_than(self, value: T) -> BoolMask:
        values: list[bool] = []
        total = i32(len(self.data))
        index = 0
        while index < total:
            values.append(self.data[index] < value)
            index += 1
        return BoolMask(values)


def contiguous_strides(shape: list[i64]) -> list[i64]:
    strides: list[i64] = []
    index = 0
    total = i32(len(shape))
    while index < total:
        strides.append(1)
        index += 1
    if total == 0:
        return strides
    index = total - 2
    while index >= 0:
        strides[index] = strides[index + 1] * shape[index + 1]
        index -= 1
    return strides


def element_count(shape: list[i64]) -> i64:
    count: i64 = 1
    index = 0
    total = i32(len(shape))
    while index < total:
        count *= shape[index]
        index += 1
    return count


def tensor_from_data_shape[T](data: list[T], shape: list[i64]) -> Tensor[T]:
    strides = contiguous_strides(shape)
    return tensor_from_data_shape_strides[T](data, shape, strides, 0)


def tensor_from_data_shape_strides[T](
    data: list[T],
    shape: list[i64],
    strides: list[i64],
    offset: i64,
) -> Tensor[T]:
    cartesian = CartesianIndexer[T](&data, shape, strides, offset)
    tensor = Tensor[T](data, shape, strides, offset, cartesian)
    tensor.cartesian = CartesianIndexer[T](&tensor.data, tensor.shape, tensor.strides, tensor.offset)
    return tensor


def tensor_from_shape[T](shape: list[i64]) -> Tensor[T]:
    data: list[T] = []
    count = element_count(shape)
    index: i64 = 0
    while index < count:
        data.append(cpp("T{}"))
        index += 1
    return tensor_from_data_shape[T](data, shape)


def zeros[T, Dims...](*dims: Dims) -> Tensor[T]:
    shape: list[i64] = cpp("ndad::shape_from_dims(dims...)")
    return tensor_from_shape[T](shape)


def arange(count: i64) -> Tensor[i64]:
    tensor = zeros[i64](count)
    index: i64 = 0
    while index < count:
        tensor.data[index] = index
        index += 1
    return tensor


def array[T](values: list[T]) -> Tensor[T]:
    shape: list[i64] = []
    shape.append(i64(len(values)))
    return tensor_from_data_shape[T](values, shape)


def can_broadcast[T](left: Tensor[T], right: Tensor[T]) -> bool:
    return cpp("ndad::broadcast_compatible(left.shape, right.shape)")


def matmul[T, M, K, N](
    left: Tensor[T][M, K],
    right: Tensor[T][K, N],
) -> Tensor[T][M, N]:
    shape: list[i64] = []
    if len(left.shape) > 0:
        shape.append(left.shape[0])
    if len(right.shape) > 1:
        shape.append(right.shape[1])
    data: list[T] = []
    return tensor_from_data_shape[T](data, shape)
