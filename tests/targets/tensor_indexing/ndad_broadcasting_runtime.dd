# Target: broadcasting is library-owned tensor behavior behind normal operators.

from ndad import Tensor
from ndad import array
from ndad import zeros


def main() -> i32:
    x: Tensor[i32][2, 3] = zeros[i32](2, 3)
    index = 0
    while index < 6:
        x.data[index] = index + 1
        index += 1

    mean: Tensor[i32][3] = array[i32]([1, 2, 3])
    inv_std: Tensor[i32][3] = array[i32]([2, 3, 4])
    x_norm: Tensor[i32][2, 3] = (x - mean[None, :]) * inv_std[None, :]

    if x_norm.shape[0] != 2:
        return 1
    if x_norm.shape[1] != 3:
        return 2
    if x_norm.data[0] != 0:
        return 3
    if x_norm.data[1] != 0:
        return 4
    if x_norm.data[2] != 0:
        return 5
    if x_norm.data[3] != 6:
        return 6
    if x_norm.data[4] != 9:
        return 7
    if x_norm.data[5] != 12:
        return 8

    row_bias: Tensor[i32][1, 3] = array[i32]([10, 20, 30])[None, :].to_tensor()
    biased: Tensor[i32][2, 3] = x + row_bias
    if biased.data[0] != 11:
        return 9
    if biased.data[5] != 36:
        return 10

    return 0
