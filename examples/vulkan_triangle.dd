# Vulkan API struct setup without creating a device.

import c "vulkan/vulkan.h" as vk


def main() -> i32:
    app: struct VkApplicationInfo
    app.sType = vk.VK_STRUCTURE_TYPE_APPLICATION_INFO
    app.pApplicationName = "dudu vulkan"
    app.applicationVersion = 1
    app.apiVersion = vk.VK_API_VERSION_1_0

    if app.sType != vk.VK_STRUCTURE_TYPE_APPLICATION_INFO:
        return 1
    return 42
