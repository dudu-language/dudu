# Print the first Fibonacci numbers.


def fib(n: i32) -> i32:
    if n <= 1:
        return n

    prev: i32 = 0
    curr: i32 = 1
    i: i32 = 2

    while i <= n:
        next: i32 = prev + curr
        prev = curr
        curr = next
        i += 1

    return curr


def main() -> i32:
    i: i32 = 0
    while i < 12:
        print(fib(i))
        i += 1
    return 0
